import os
import pandas as pd
import numpy as np

# Folder containing the signal trace CSV files
folder = '/home/zainab/Desktop/My_Project_Zainab/SamePower/Gaussian'
output_file = 'Gaussian_Metrix_Evaluation.csv'

results = []

if os.path.exists(folder):
    for filename in sorted(os.listdir(folder)):
        if filename.endswith('.csv'):
            filepath = os.path.join(folder, filename)
            try:
                df = pd.read_csv(filepath)

                if 'Power_dBHz' in df.columns and 'Frequency_MHz' in df.columns:
                    amplitudes = df['Power_dBHz'].dropna().values
                    frequencies = df['Frequency_MHz'].dropna().values

                    # 1. Noise Floor (Bottom 15% of sorted data)
                    sorted_amplitudes = np.sort(amplitudes)
                    n = len(sorted_amplitudes)
                    noise_floor = np.mean(sorted_amplitudes[:int(0.15 * n)])

                    # 2. Signal Power (Average of points above the noise floor)
                    # This ensures the signal power is accurate for ML
                    threshold = noise_floor + 5
                    signal_points = amplitudes[amplitudes > threshold]
                    if len(signal_points) > 0:
                        signal_power = np.mean(signal_points)
                    else:
                        signal_power = noise_floor

                    # 3. SNR
                    snr = signal_power - noise_floor

                    # 4. Edge Frequency Average (Goal: -6dB from the Peak)
                    peak_val = np.max(amplitudes)
                    edge_threshold = peak_val - 6
                    signal_indices = np.where(amplitudes > edge_threshold)[0]

                    if len(signal_indices) > 0:
                        freq_start_edge = frequencies[signal_indices[0]]
                        freq_end_edge = frequencies[signal_indices[-1]]
                        edge_freq_avg = (freq_start_edge + freq_end_edge) / 2
                    else:
                        edge_freq_avg = 0

                    # Store only original requested features
                    results.append({
                        'Trace': filename,
                        'Signal Power (dBHz)': signal_power,
                        'Noise Floor (dBHz)': noise_floor,
                        'SNR (dB)': snr,
                        'Edge Frequency Avg (MHz)': edge_freq_avg
                    })

            except Exception as e:
                print(f"Error processing {filename}: {e}")

# Save results to CSV
df_results = pd.DataFrame(results)
df_results.to_csv(output_file, index=False)

print(f"Feature extraction complete. Matrix saved to {output_file}")
