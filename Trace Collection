from rtlsdr import RtlSdr
import numpy as np
import matplotlib
import os
matplotlib.use('Agg')
import matplotlib.pyplot as plt

# --- CONFIGURATION & FOLDER SETUP ---
folder = '/home/zainab/Desktop/My_Project_Zainab/SamePower/Gaussian'
os.makedirs(folder, exist_ok=True)

sdr = RtlSdr()
sdr.sample_rate = 2.4e6 # Hz
sdr.center_freq = 467.5625e6 # Hz
sdr.freq_correction = 60 # PPM

print(sdr.valid_gains_db)
sdr.gain = 49.6
print(sdr.gain)
fft_size = 8192
num_rows = 500

sdr.read_samples(2048) # to ignore the first 2k because it is just the noise 
x = sdr.read_samples(4096)

# --- 1. TIME DOMAIN  ---
plt.figure()
plt.plot(x.real)
plt.plot(x.imag)
plt.legend(["I", "Q"])
plt.xlabel("Sample index")
plt.ylabel("Amplitude")
plt.title("Time-domain signal")
# The Time Domain Figure Location
plt.savefig("/home/zainab/Desktop/My_Project_Zainab/SamePower/rtlsdr-gain(Clear).svg", bbox_inches='tight')
plt.close()

# --- 2. FREQUENCY DOMAIN (Added from PySDR website) ---
Fs = sdr.sample_rate
N = len(x)
win = np.hamming(N)
X = np.fft.fftshift(np.fft.fft(x * win))
psd = 10 * np.log10(np.abs(X)**2 / (N * Fs))
f = np.fft.fftshift(np.fft.fftfreq(N, d=1/Fs)) / 1e6
f_actual = f + sdr.center_freq / 1e6

plt.figure()
plt.plot(f_actual, psd)
plt.xlabel("Frequency [MHz]")
plt.ylabel("PSD [dB/Hz]")
plt.title("Frequency Domain")
plt.grid(True)
# The Frequency Domain Figure Location
plt.savefig("/home/zainab/Desktop/My_Project_Zainab/SamePower/frequency_domain(Gaussian).svg", bbox_inches='tight')
plt.close()

# --- 3. SPECTROGRAM & TRACE COLLECTION ---
x_large = sdr.read_samples(fft_size * num_rows)
sdr.close()

spectrogram = np.zeros((num_rows, fft_size))
# Prepare the frequency axis for both CSVs and the Plot
freqs_axis = (np.fft.fftshift(np.fft.fftfreq(fft_size, d=1/Fs)) / 1e6) + (sdr.center_freq / 1e6)

print(f"Starting trace collection: Saving {num_rows} files to {folder}...")

# 1. THE LOOP (Collects Traces and populates the Spectrogram matrix)
for i in range(num_rows):
    print(f"\rProcessing: Trace {i + 1}/{num_rows}", end="")
    
    segment = x_large[i*fft_size : (i+1)*fft_size]
    
    # Calculate PSD
    row_psd = 10 * np.log10(np.abs(np.fft.fftshift(np.fft.fft(segment * np.hamming(fft_size))))**2 / (fft_size * Fs))
    
    # Store in spectrogram matrix for the final image
    spectrogram[i, :] = row_psd
    
    # Save individual CSV trace
    trace_filename = os.path.join(folder, f'Trace_{i + 1:03d}.csv')
    np.savetxt(trace_filename, np.column_stack((freqs_axis, row_psd)), 
               delimiter=',', header='Frequency_MHz,Power_dBHz', comments='')

print("\nCollection complete!")

# 2. THE IMAGE (Saves the spectrogram plot after the loop)
times = np.arange(num_rows) * fft_size / Fs

plt.figure(figsize=(10,6))
plt.imshow(spectrogram, aspect='auto',
           extent=[freqs_axis[0], freqs_axis[-1], times[-1], times[0]],
           origin='lower', cmap='viridis')
plt.xlabel("Frequency [MHz]")
plt.ylabel("Time [s]")
plt.title("Spectrogram")
plt.colorbar(label="Power [dB/Hz]")
# The spectrogram Figure Location
plt.savefig("/home/zainab/Desktop/My_Project_Zainab/SamePower/spectrogram(Gaussian).svg", bbox_inches='tight')
plt.close()

