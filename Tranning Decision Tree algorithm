import pandas as pd
from sklearn.tree import DecisionTreeClassifier
import joblib  # Used to save the model for later use

# 1. Load your master dataset
# Make sure this filename matches the one created earlier
file_path = '/home/zainab/Desktop/My_Project_Zainab/Master_Training_Data2.csv'
data = pd.read_csv(file_path)

# 2. Prepare X (Features) and y (Labels)
X = data.drop(columns=['Label', 'Trace'])
y = data['Label']

print(f"Training on {len(data)} traces with features: {list(X.columns)}")

# 3. Initialize the Decision Tree
# 'random_state=42' ensures the results are the same every time you run it
clf = DecisionTreeClassifier(random_state=42)

# 4. Train the model on 100% of the data
clf.fit(X, y)

print("Training complete!")

# 5. Save the trained model to a file
model_filename = '//home/zainab/Desktop/My_Project_Zainab/jamming_decision_tree_model.pkl'
joblib.dump(clf, model_filename)

print(f"Model saved as: {model_filename}")

# Optional: Print how important each feature was
for feature, importance in zip(X.columns, clf.feature_importances_):
    print(f"Feature: {feature:25} Importance: {importance:.4f}")

